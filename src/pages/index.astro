---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---
<Base
  title="FieldSketch — Field Inspection Sketches, Done Right"
  description="Purpose-built for field engineers, site inspectors, architects, and construction professionals. Sketch on your tablet, export clean PDFs, drop them in your reports."
>
  <div class="min-h-screen">

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-field-white/80 backdrop-blur-xl border-b border-field-blue/8">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="https://sketchkit.app" class="text-sm font-medium text-sketch-gray hover:text-ink transition-colors flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SketchKit
        </a>
        <span class="font-field font-bold text-ink tracking-tight">FieldSketch</span>
        <a href="https://moodsketch.app" class="text-sm font-medium text-sketch-gray hover:text-ink transition-colors flex items-center gap-1">
          MoodSketch
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="noise relative bg-gradient-to-br from-field-blue to-field-dark text-white pt-32 pb-40 px-6 overflow-hidden">
      <!-- Blueprint grid overlay -->
      <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-hero" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-hero)"/>
      </svg>
      <!-- Decorative measurement line -->
      <div class="absolute bottom-16 left-8 right-8 hidden lg:flex items-center gap-2 opacity-[0.08]">
        <div class="h-px flex-1 bg-white"></div>
        <span class="font-mono text-[10px] text-white shrink-0">1920px</span>
        <div class="h-px flex-1 bg-white"></div>
      </div>

      <div class="max-w-5xl mx-auto hero-stagger relative">
        <p class="font-mono text-xs tracking-[0.3em] uppercase text-field-blue-light/50 mb-8">For Android Tablets</p>

        <h1 class="font-field font-bold tracking-tight text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[0.9] mb-8 max-w-4xl">
          Built for the way<br/>you actually work.
        </h1>

        <p class="text-white/45 text-lg md:text-xl max-w-xl leading-relaxed mb-14">
          Replace your clipboard and paper notebook with something that actually works in the field. Sketch, annotate, export — done.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-white/15 backdrop-blur border border-white/20 text-white font-semibold text-base transition-all hover:bg-white/25">
            App Store &mdash; Coming Soon
          </button>
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-white/8 backdrop-blur border border-white/10 text-white/70 font-medium text-base transition-all hover:bg-white/15">
            Google Play &mdash; Coming Soon
          </button>
        </div>
      </div>
    </section>

    <!-- Audience callout -->
    <section class="bg-field-blue/[0.03] border-b border-field-grid py-6 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-center text-field-slate text-sm font-mono tracking-wide">
          Built for
          <span class="text-ink font-semibold font-sans"> field engineers</span> &middot;
          <span class="text-ink font-semibold font-sans"> site inspectors</span> &middot;
          <span class="text-ink font-semibold font-sans"> architects</span> &middot;
          <span class="text-ink font-semibold font-sans"> construction professionals</span>
        </p>
      </div>
    </section>

    <!-- Features -->
    <section class="py-28 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-field-blue mb-4">Features</p>
          <h2 class="font-field font-bold tracking-tight text-4xl md:text-5xl text-ink">Purpose-built tools.</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-10">
          <div class="reveal" style="transition-delay: 0s">
            <div class="w-14 h-14 rounded-xl bg-field-blue/8 flex items-center justify-center mb-6">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            </div>
            <h3 class="font-field font-bold tracking-tight text-xl text-ink mb-3">Built for the Field</h3>
            <p class="text-field-slate leading-relaxed">Optimized for tablets. Gloves-friendly touch targets. Works completely offline — no signal, no problem.</p>
            <div class="mt-4 flex gap-2">
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/5 text-field-blue font-mono text-[11px]">offline-first</span>
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/5 text-field-blue font-mono text-[11px]">touch-optimized</span>
            </div>
          </div>
          <div class="reveal" style="transition-delay: 0.1s">
            <div class="w-14 h-14 rounded-xl bg-field-blue/8 flex items-center justify-center mb-6">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <h3 class="font-field font-bold tracking-tight text-xl text-ink mb-3">Report-Ready Output</h3>
            <p class="text-field-slate leading-relaxed">Export clean, professional PDFs with one tap. Drop them straight into your reports. No scanning, no cleanup.</p>
            <div class="mt-4 flex gap-2">
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/5 text-field-blue font-mono text-[11px]">one-tap PDF</span>
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/5 text-field-blue font-mono text-[11px]">print-ready</span>
            </div>
          </div>
          <div class="reveal" style="transition-delay: 0.2s">
            <div class="w-14 h-14 rounded-xl bg-field-blue/8 flex items-center justify-center mb-6">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            </div>
            <h3 class="font-field font-bold tracking-tight text-xl text-ink mb-3">Smart Templates</h3>
            <p class="text-field-slate leading-relaxed">Pre-built templates for common inspection types — pipe layouts, floor plans, site overviews, mechanical diagrams.</p>
            <div class="mt-4 flex gap-2">
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/5 text-field-blue font-mono text-[11px]">pre-built</span>
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/5 text-field-blue font-mono text-[11px]">customizable</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats strip -->
    <section class="bg-field-dark py-12 px-6">
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="reveal" style="transition-delay: 0s">
          <p class="font-mono font-semibold text-3xl md:text-4xl text-white mb-1">20+</p>
          <p class="font-mono text-xs text-white/40 uppercase tracking-wider">min saved / inspection</p>
        </div>
        <div class="reveal" style="transition-delay: 0.1s">
          <p class="font-mono font-semibold text-3xl md:text-4xl text-white mb-1">1-tap</p>
          <p class="font-mono text-xs text-white/40 uppercase tracking-wider">PDF export</p>
        </div>
        <div class="reveal" style="transition-delay: 0.2s">
          <p class="font-mono font-semibold text-3xl md:text-4xl text-white mb-1">100%</p>
          <p class="font-mono text-xs text-white/40 uppercase tracking-wider">offline capable</p>
        </div>
        <div class="reveal" style="transition-delay: 0.3s">
          <p class="font-mono font-semibold text-3xl md:text-4xl text-white mb-1">0</p>
          <p class="font-mono text-xs text-white/40 uppercase tracking-wider">paper needed</p>
        </div>
      </div>
    </section>

    <!-- Before / After -->
    <section class="noise relative py-28 px-6 overflow-hidden" style="background: linear-gradient(135deg, #f0f4f8 0%, #f8fafc 50%, #edf2f7 100%);">
      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-ba" width="32" height="32" patternUnits="userSpaceOnUse">
            <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#1D4ED8" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-ba)"/>
      </svg>

      <div class="max-w-4xl mx-auto relative">
        <div class="text-center mb-16 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-field-blue mb-4">The Difference</p>
          <h2 class="font-field font-bold tracking-tight text-4xl md:text-5xl text-ink">Before & After.</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Before -->
          <div class="reveal-left rounded-3xl p-8 bg-white border-2 border-field-grid/60">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </div>
              <p class="text-field-slate text-sm font-mono font-medium uppercase tracking-wider">Before</p>
            </div>
            <!-- Paper clipboard mock -->
            <div class="mb-6 rounded-xl border-2 border-dashed border-field-grid/60 bg-field-white p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-3 h-3 rounded-sm bg-field-grid/50"></div>
                <div class="h-1.5 w-20 bg-field-grid/40 rounded"></div>
              </div>
              <div class="space-y-2">
                <div class="h-1 w-full bg-field-grid/30 rounded"></div>
                <div class="h-1 w-2/3 bg-field-grid/30 rounded"></div>
                <div class="h-6 w-12 border border-field-grid/40 rounded mt-3"></div>
              </div>
              <p class="font-mono text-[10px] text-field-grid mt-3 italic">illegible_scan.jpg</p>
            </div>
            <ul class="space-y-4">
              <li class="flex items-start gap-3 text-field-slate">
                <span class="text-red-400 mt-0.5 flex-shrink-0 font-mono text-xs">01</span>
                <span>Paper sketch on clipboard, hard to read later</span>
              </li>
              <li class="flex items-start gap-3 text-field-slate">
                <span class="text-red-400 mt-0.5 flex-shrink-0 font-mono text-xs">02</span>
                <span>Photograph the whiteboard, hope the lighting is okay</span>
              </li>
              <li class="flex items-start gap-3 text-field-slate">
                <span class="text-red-400 mt-0.5 flex-shrink-0 font-mono text-xs">03</span>
                <span>Redraw the sketch in the office for the report</span>
              </li>
              <li class="flex items-start gap-3 text-field-slate">
                <span class="text-red-400 mt-0.5 flex-shrink-0 font-mono text-xs">04</span>
                <div>
                  <span>20-30 minutes of cleanup per inspection</span>
                  <span class="block mt-1 text-xs font-mono text-red-400/60">~2.5 hrs/week wasted</span>
                </div>
              </li>
            </ul>
          </div>
          <!-- After -->
          <div class="reveal-right rounded-3xl p-8 bg-gradient-to-br from-field-blue to-field-dark text-white relative overflow-hidden">
            <svg class="absolute inset-0 w-full h-full opacity-[0.06]" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="bp-after" width="24" height="24" patternUnits="userSpaceOnUse">
                  <path d="M 24 0 L 0 0 0 24" fill="none" stroke="white" stroke-width="0.5"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#bp-after)"/>
            </svg>
            <div class="relative">
              <div class="flex items-center gap-3 mb-8">
                <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p class="text-white/60 text-sm font-mono font-medium uppercase tracking-wider">After</p>
              </div>
              <!-- Tablet sketch mock -->
              <div class="mb-6 rounded-xl border border-white/10 bg-white/5 p-4">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-2 h-2 rounded-full bg-field-blue-light/60"></div>
                  <div class="h-1.5 w-16 bg-white/15 rounded"></div>
                  <div class="ml-auto font-mono text-[10px] text-white/30">PDF</div>
                </div>
                <div class="space-y-2">
                  <div class="h-1 w-full bg-white/10 rounded"></div>
                  <div class="h-1 w-4/5 bg-white/10 rounded"></div>
                  <div class="flex gap-2 mt-3">
                    <div class="h-8 w-8 rounded border border-white/15 bg-white/5"></div>
                    <div class="h-8 w-8 rounded border border-white/15 bg-white/5"></div>
                    <div class="h-8 w-8 rounded border border-field-blue-light/40 bg-field-blue/10"></div>
                  </div>
                </div>
                <p class="font-mono text-[10px] text-field-blue-light/40 mt-3">inspection_042.pdf &#10003;</p>
              </div>
              <ul class="space-y-4">
                <li class="flex items-start gap-3 text-white/90">
                  <span class="text-field-blue-light mt-0.5 flex-shrink-0 font-mono text-xs">01</span>
                  <span>Sketch on tablet, clean and legible every time</span>
                </li>
                <li class="flex items-start gap-3 text-white/90">
                  <span class="text-field-blue-light mt-0.5 flex-shrink-0 font-mono text-xs">02</span>
                  <span>One-tap PDF export, report-ready immediately</span>
                </li>
                <li class="flex items-start gap-3 text-white/90">
                  <span class="text-field-blue-light mt-0.5 flex-shrink-0 font-mono text-xs">03</span>
                  <span>Drop the PDF straight into your report</span>
                </li>
                <li class="flex items-start gap-3 text-white/90">
                  <span class="text-field-blue-light mt-0.5 flex-shrink-0 font-mono text-xs">04</span>
                  <div>
                    <span>Save 20+ minutes per inspection</span>
                    <span class="block mt-1 text-xs font-mono text-field-blue-light/50">~2.5 hrs/week saved</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-28 px-6 bg-field-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-field-blue mb-4">Workflow</p>
          <h2 class="font-field font-bold tracking-tight text-4xl md:text-5xl text-ink">Simple as 1-2-3.</h2>
        </div>
        <div class="space-y-16">
          <div class="reveal flex gap-8 items-start">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-field-blue to-field-dark text-white font-mono font-bold text-xl flex items-center justify-center shadow-lg shadow-field-blue/20">01</div>
            <div>
              <h3 class="font-field font-bold tracking-tight text-2xl text-ink mb-3">Open a template</h3>
              <p class="text-field-slate text-lg leading-relaxed">Pick from pre-built templates for your inspection type — pipe layouts, floor plans, site overviews. Or start with a blank canvas.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 items-start" style="transition-delay: 0.12s">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-field-blue to-field-dark text-white font-mono font-bold text-xl flex items-center justify-center shadow-lg shadow-field-blue/20">02</div>
            <div>
              <h3 class="font-field font-bold tracking-tight text-2xl text-ink mb-3">Sketch & annotate</h3>
              <p class="text-field-slate text-lg leading-relaxed">Draw with precision tools designed for field work. Add labels, measurements, and notes. Gloves-friendly targets, works in any conditions.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 items-start" style="transition-delay: 0.24s">
            <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-field-blue-light to-field-blue text-white font-mono font-bold text-xl flex items-center justify-center shadow-lg shadow-field-blue/20">03</div>
            <div>
              <h3 class="font-field font-bold tracking-tight text-2xl text-ink mb-3">Export & report</h3>
              <p class="text-field-slate text-lg leading-relaxed">One tap to generate a clean, professional PDF. Drop it straight into your report. No scanning, no redrawing, no wasted time.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-28 px-6 bg-field-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-field-blue mb-4">Pricing</p>
          <h2 class="font-field font-bold tracking-tight text-4xl md:text-5xl text-ink mb-3">Simple pricing.</h2>
          <p class="text-field-slate text-lg">Professional tools shouldn't cost a fortune. Expensable on most project budgets.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Free -->
          <div class="reveal rounded-3xl p-8 border-2 border-field-grid/60 bg-white">
            <p class="text-sketch-gray text-sm font-medium mb-2">Free</p>
            <p class="font-field font-bold tracking-tight text-5xl text-ink mb-1">$0</p>
            <p class="text-sketch-gray text-sm mb-8">Forever free</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue font-bold">&#10003;</span> Core drawing tools</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue font-bold">&#10003;</span> 5 saved sketches</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue font-bold">&#10003;</span> PDF export (watermarked)</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/40"><span>&#10007;</span> Unlimited sketches</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/40"><span>&#10007;</span> Clean PDF export</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/40"><span>&#10007;</span> Templates library</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/40"><span>&#10007;</span> Cloud sync</li>
            </ul>
            <button class="w-full py-3.5 rounded-2xl border-2 border-field-grid text-sketch-gray font-semibold text-sm hover:border-field-blue hover:text-field-blue transition-colors">
              Coming soon
            </button>
          </div>
          <!-- Pro -->
          <div class="reveal relative overflow-hidden rounded-3xl p-8 bg-gradient-to-br from-field-blue to-field-dark text-white" style="transition-delay: 0.1s">
            <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="bp-price" width="20" height="20" patternUnits="userSpaceOnUse">
                  <path d="M 20 0 L 0 0 0 20" fill="none" stroke="white" stroke-width="0.5"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#bp-price)"/>
            </svg>
            <div class="relative">
              <div class="flex items-center justify-between mb-2">
                <p class="text-white/70 text-sm font-medium">Pro</p>
                <span class="px-2.5 py-1 rounded-full bg-white/10 font-mono text-[11px] text-white/60">most popular</span>
              </div>
              <p class="font-field font-bold tracking-tight text-5xl mb-1">$9.99<span class="text-2xl font-normal text-white/60">/mo</span></p>
              <p class="text-white/50 text-sm mb-8">or $79.99/yr — save 33%</p>
              <ul class="space-y-3 mb-8">
                <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light font-bold">&#10003;</span> Everything in Free</li>
                <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light font-bold">&#10003;</span> Unlimited sketches</li>
                <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light font-bold">&#10003;</span> Clean PDF export</li>
                <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light font-bold">&#10003;</span> Full template library</li>
                <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light font-bold">&#10003;</span> Cloud sync</li>
                <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light font-bold">&#10003;</span> Priority support</li>
              </ul>
              <button class="cta-pulse w-full py-3.5 rounded-2xl bg-white text-field-blue font-semibold text-sm hover:bg-white/90 transition-colors shadow-lg shadow-field-dark/30">
                Coming soon
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Email Capture -->
    <section class="noise bg-field-dark py-28 px-6 relative overflow-hidden">
      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-email" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-email)"/>
      </svg>
      <div class="max-w-lg mx-auto text-center reveal relative">
        <p class="font-mono text-xs tracking-[0.3em] uppercase text-field-blue-light/50 mb-6">Early Access</p>
        <h2 class="font-field font-bold tracking-tight text-4xl md:text-5xl text-white mb-4">Get early access.</h2>
        <p class="text-white/40 text-lg mb-3">Get notified when FieldSketch launches.</p>
