---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---
<Base
  title="FieldSketch — Field Inspection Sketches, Done Right"
  description="Purpose-built for field engineers, site inspectors, architects, and construction professionals. Sketch on your tablet, export clean PDFs, drop them in your reports."
>
  <div class="min-h-screen">

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-field-white/80 backdrop-blur-xl border-b border-field-blue/[0.06]">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
        <a href="https://sketchkit.app" class="text-sm font-display font-medium text-sketch-gray hover:text-ink transition-colors duration-300 flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SketchKit
        </a>
        <span class="font-field font-bold text-ink tracking-tight text-lg">FieldSketch</span>
        <a href="https://moodsketch.app" class="text-sm font-display font-medium text-sketch-gray hover:text-ink transition-colors duration-300 flex items-center gap-1.5">
          MoodSketch
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="noise relative text-white pt-32 pb-44 px-6 md:px-10 overflow-hidden" style="background: linear-gradient(140deg, #1D4ED8 0%, #1a3f9e 40%, #1E3A5F 100%);">
      <!-- Blueprint grid overlay -->
      <svg class="absolute inset-0 w-full h-full opacity-[0.035]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-hero" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="white" stroke-width="0.35"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-hero)"/>
      </svg>
      <!-- Gradient orbs -->
      <div class="absolute top-[-10%] right-[-5%] w-[40%] h-[50%] bg-field-blue-light/[0.08] rounded-full blur-[120px]"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[35%] h-[45%] bg-field-dark/20 rounded-full blur-[100px]"></div>
      <!-- Decorative measurement line -->
      <div class="absolute bottom-20 left-10 right-10 hidden lg:flex items-center gap-3 opacity-[0.06]" style="z-index:1">
        <div class="h-px flex-1 bg-white"></div>
        <span class="font-mono text-[9px] text-white shrink-0 tracking-wider">VIEWPORT</span>
        <div class="h-px flex-1 bg-white"></div>
      </div>

      <div class="max-w-5xl mx-auto hero-stagger relative">
        <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-field-blue-light/35 mb-10">For Android Tablets</p>

        <h1 class="font-field font-bold tracking-[-0.03em] text-[clamp(2.5rem,8vw,5.5rem)] leading-[0.92] mb-8 max-w-4xl">
          Built for the way you actually work.
        </h1>

        <p class="text-white/35 text-lg md:text-xl max-w-xl leading-[1.7] mb-16 font-light">
          Replace your clipboard and paper notebook with something that actually works in the field. Sketch, annotate, export — done.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-9 py-4 rounded-2xl bg-white/15 backdrop-blur-sm border border-white/15 text-white font-display font-semibold text-[0.9rem] transition-all hover:bg-white/25">
            Google Play &mdash; Coming Soon
          </button>
          <button class="cta-pulse inline-flex items-center justify-center gap-2 px-9 py-4 rounded-2xl bg-white/[0.06] backdrop-blur-sm border border-white/[0.08] text-white/60 font-display font-medium text-[0.9rem] transition-all hover:bg-white/12">
            Learn more
          </button>
        </div>
      </div>

      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-field-white to-transparent" style="z-index:2"></div>
    </section>

    <!-- Audience callout -->
    <section class="bg-field-blue/[0.02] border-b border-field-grid/60 py-7 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-center text-field-slate text-sm font-mono tracking-wider">
          Built for
          <span class="text-ink font-semibold font-sans"> field engineers</span> &middot;
          <span class="text-ink font-semibold font-sans"> site inspectors</span> &middot;
          <span class="text-ink font-semibold font-sans"> architects</span> &middot;
          <span class="text-ink font-semibold font-sans"> construction professionals</span>
        </p>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="py-32 px-6 md:px-10">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-field-blue mb-5">Features</p>
          <h2 class="font-field font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink leading-tight">Purpose-built tools.</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-12 stagger-children">
          <div class="reveal">
            <div class="w-14 h-14 rounded-xl bg-field-blue/[0.06] flex items-center justify-center mb-7">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--field-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            </div>
            <h3 class="font-field font-bold tracking-tight text-xl text-ink mb-4">Built for the Field</h3>
            <p class="text-field-slate leading-[1.8] text-[0.95rem]">Optimized for tablets. Gloves-friendly touch targets. Works completely offline — no signal, no problem.</p>
            <div class="mt-5 flex gap-2">
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/[0.04] text-field-blue font-mono text-[0.65rem] tracking-wide">offline-first</span>
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/[0.04] text-field-blue font-mono text-[0.65rem] tracking-wide">touch-optimized</span>
            </div>
          </div>
          <div class="reveal">
            <div class="w-14 h-14 rounded-xl bg-field-blue/[0.06] flex items-center justify-center mb-7">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--field-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <h3 class="font-field font-bold tracking-tight text-xl text-ink mb-4">Report-Ready Output</h3>
            <p class="text-field-slate leading-[1.8] text-[0.95rem]">Export clean, professional PDFs with one tap. Drop them straight into your reports. No scanning, no cleanup.</p>
            <div class="mt-5 flex gap-2">
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/[0.04] text-field-blue font-mono text-[0.65rem] tracking-wide">one-tap PDF</span>
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/[0.04] text-field-blue font-mono text-[0.65rem] tracking-wide">print-ready</span>
            </div>
          </div>
          <div class="reveal">
            <div class="w-14 h-14 rounded-xl bg-field-blue/[0.06] flex items-center justify-center mb-7">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--field-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            </div>
            <h3 class="font-field font-bold tracking-tight text-xl text-ink mb-4">Smart Templates</h3>
            <p class="text-field-slate leading-[1.8] text-[0.95rem]">Pre-built templates for common inspection types — pipe layouts, floor plans, site overviews, mechanical diagrams.</p>
            <div class="mt-5 flex gap-2">
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/[0.04] text-field-blue font-mono text-[0.65rem] tracking-wide">pre-built</span>
              <span class="inline-block px-2.5 py-1 rounded-md bg-field-blue/[0.04] text-field-blue font-mono text-[0.65rem] tracking-wide">customizable</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== STATS STRIP ===== -->
    <section class="noise py-16 px-6 md:px-10 overflow-hidden" style="background: var(--field-dark);">
      <svg class="absolute inset-0 w-full h-full opacity-[0.025]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-stats" width="32" height="32" patternUnits="userSpaceOnUse">
            <path d="M 32 0 L 0 0 0 32" fill="none" stroke="white" stroke-width="0.3"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-stats)"/>
      </svg>
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center relative stagger-children">
        <div class="reveal">
          <p class="font-mono font-semibold text-3xl md:text-[2.5rem] text-white mb-2 tracking-tight">20+</p>
          <p class="font-mono text-[0.6rem] text-white/30 uppercase tracking-[0.2em]">min saved / inspection</p>
        </div>
        <div class="reveal">
          <p class="font-mono font-semibold text-3xl md:text-[2.5rem] text-white mb-2 tracking-tight">1-tap</p>
          <p class="font-mono text-[0.6rem] text-white/30 uppercase tracking-[0.2em]">PDF export</p>
        </div>
        <div class="reveal">
          <p class="font-mono font-semibold text-3xl md:text-[2.5rem] text-white mb-2 tracking-tight">100%</p>
          <p class="font-mono text-[0.6rem] text-white/30 uppercase tracking-[0.2em]">offline capable</p>
        </div>
        <div class="reveal">
          <p class="font-mono font-semibold text-3xl md:text-[2.5rem] text-white mb-2 tracking-tight">0</p>
          <p class="font-mono text-[0.6rem] text-white/30 uppercase tracking-[0.2em]">paper needed</p>
        </div>
      </div>
    </section>

    <!-- ===== BEFORE / AFTER ===== -->
    <section class="noise relative py-32 px-6 md:px-10 overflow-hidden" style="background: linear-gradient(150deg, #f0f4f8 0%, #f8fafc 50%, #eef2f7 100%);">
      <svg class="absolute inset-0 w-full h-full opacity-[0.02]" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-ba" width="32" height="32" patternUnits="userSpaceOnUse">
            <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#1D4ED8" stroke-width="0.35"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-ba)"/>
      </svg>

      <div class="max-w-4xl mx-auto relative">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-field-blue mb-5">The Difference</p>
          <h2 class="font-field font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink leading-tight">Before & After.</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-7">
          <!-- Before -->
          <div class="reveal-left rounded-[1.5rem] p-9 bg-white border border-field-grid/40 shadow-sm">
            <div class="flex items-center gap-3 mb-9">
              <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </div>
              <p class="text-field-slate text-sm font-mono tracking-wider uppercase">Before</p>
            </div>
            <!-- Paper clipboard mock -->
            <div class="mb-7 rounded-xl border-2 border-dashed border-field-grid/50 bg-field-white p-5">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-3 h-3 rounded-sm bg-field-grid/40"></div>
                <div class="h-1.5 w-20 bg-field-grid/30 rounded-full"></div>
              </div>
              <div class="space-y-2">
                <div class="h-1 w-full bg-field-grid/25 rounded-full"></div>
                <div class="h-1 w-2/3 bg-field-grid/25 rounded-full"></div>
                <div class="h-6 w-12 border border-field-grid/30 rounded mt-3"></div>
              </div>
              <p class="font-mono text-[0.6rem] text-field-grid mt-3 italic">illegible_scan.jpg</p>
            </div>
            <ul class="space-y-5">
              <li class="flex items-start gap-4 text-field-slate">
                <span class="text-red-400/60 mt-0.5 flex-shrink-0 font-mono text-xs">01</span>
                <span>Paper sketch on clipboard, hard to read later</span>
              </li>
              <li class="flex items-start gap-4 text-field-slate">
                <span class="text-red-400/60 mt-0.5 flex-shrink-0 font-mono text-xs">02</span>
                <span>Photograph the whiteboard, hope the lighting is okay</span>
              </li>
              <li class="flex items-start gap-4 text-field-slate">
                <span class="text-red-400/60 mt-0.5 flex-shrink-0 font-mono text-xs">03</span>
                <span>Redraw the sketch in the office for the report</span>
              </li>
              <li class="flex items-start gap-4 text-field-slate">
                <span class="text-red-400/60 mt-0.5 flex-shrink-0 font-mono text-xs">04</span>
                <div>
                  <span>20-30 minutes of cleanup per inspection</span>
                  <span class="block mt-1.5 text-[0.65rem] font-mono text-red-400/45 tracking-wide">~2.5 hrs/week wasted</span>
                </div>
              </li>
            </ul>
          </div>
          <!-- After -->
          <div class="reveal-right rounded-[1.5rem] p-9 text-white relative overflow-hidden" style="background: linear-gradient(140deg, #1D4ED8 0%, #1a3f9e 40%, #1E3A5F 100%);">
            <svg class="absolute inset-0 w-full h-full opacity-[0.05]" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="bp-after" width="24" height="24" patternUnits="userSpaceOnUse">
                  <path d="M 24 0 L 0 0 0 24" fill="none" stroke="white" stroke-width="0.35"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#bp-after)"/>
            </svg>
            <div class="relative">
              <div class="flex items-center gap-3 mb-9">
                <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p class="text-white/50 text-sm font-mono tracking-wider uppercase">After</p>
              </div>
              <!-- Tablet sketch mock -->
              <div class="mb-7 rounded-xl border border-white/10 bg-white/[0.04] p-5">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-2.5 h-2.5 rounded-full bg-field-blue-light/50"></div>
                  <div class="h-1.5 w-16 bg-white/12 rounded-full"></div>
                  <div class="ml-auto font-mono text-[0.6rem] text-white/25 tracking-wide">PDF</div>
                </div>
                <div class="space-y-2">
                  <div class="h-1 w-full bg-white/8 rounded-full"></div>
                  <div class="h-1 w-4/5 bg-white/8 rounded-full"></div>
                  <div class="flex gap-2.5 mt-3">
                    <div class="h-8 w-8 rounded border border-white/12 bg-white/[0.03]"></div>
                    <div class="h-8 w-8 rounded border border-white/12 bg-white/[0.03]"></div>
                    <div class="h-8 w-8 rounded border border-field-blue-light/30 bg-field-blue/[0.08]"></div>
                  </div>
                </div>
                <p class="font-mono text-[0.6rem] text-field-blue-light/35 mt-3 tracking-wide">inspection_042.pdf &#10003;</p>
              </div>
              <ul class="space-y-5">
                <li class="flex items-start gap-4 text-white/85">
                  <span class="text-field-blue-light/60 mt-0.5 flex-shrink-0 font-mono text-xs">01</span>
                  <span>Sketch on tablet, clean and legible every time</span>
                </li>
                <li class="flex items-start gap-4 text-white/85">
                  <span class="text-field-blue-light/60 mt-0.5 flex-shrink-0 font-mono text-xs">02</span>
                  <span>One-tap PDF export, report-ready immediately</span>
                </li>
                <li class="flex items-start gap-4 text-white/85">
                  <span class="text-field-blue-light/60 mt-0.5 flex-shrink-0 font-mono text-xs">03</span>
                  <span>Drop the PDF straight into your report</span>
                </li>
                <li class="flex items-start gap-4 text-white/85">
                  <span class="text-field-blue-light/60 mt-0.5 flex-shrink-0 font-mono text-xs">04</span>
                  <div>
                    <span>Save 20+ minutes per inspection</span>
                    <span class="block mt-1.5 text-[0.65rem] font-mono text-field-blue-light/35 tracking-wide">~2.5 hrs/week saved</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WORKFLOW ===== -->
    <section class="py-32 px-6 md:px-10 bg-field-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-field-blue mb-5">Workflow</p>
          <h2 class="font-field font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink leading-tight">Simple as 1-2-3.</h2>
        </div>
        <div class="space-y-20">
          <div class="reveal flex gap-8 md:gap-10 items-start">
            <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-field-blue to-field-dark text-white font-mono font-bold text-xl flex items-center justify-center shadow-xl shadow-field-blue/15">01</div>
            <div class="pt-2">
              <h3 class="font-field font-bold tracking-tight text-2xl md:text-[1.65rem] text-ink mb-4">Open a template</h3>
              <p class="text-field-slate text-lg leading-[1.8]">Pick from pre-built templates for your inspection type — pipe layouts, floor plans, site overviews. Or start with a blank canvas.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 md:gap-10 items-start" style="transition-delay: 0.12s">
            <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-field-blue to-field-dark text-white font-mono font-bold text-xl flex items-center justify-center shadow-xl shadow-field-blue/15">02</div>
            <div class="pt-2">
              <h3 class="font-field font-bold tracking-tight text-2xl md:text-[1.65rem] text-ink mb-4">Sketch & annotate</h3>
              <p class="text-field-slate text-lg leading-[1.8]">Draw with precision tools designed for field work. Add labels, measurements, and notes. Gloves-friendly targets, works in any conditions.</p>
            </div>
          </div>
          <div class="reveal flex gap-8 md:gap-10 items-start" style="transition-delay: 0.24s">
            <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-field-blue-light to-field-blue text-white font-mono font-bold text-xl flex items-center justify-center shadow-xl shadow-field-blue/15">03</div>
            <div class="pt-2">
              <h3 class="font-field font-bold tracking-tight text-2xl md:text-[1.65rem] text-ink mb-4">Export & report</h3>
              <p class="text-field-slate text-lg leading-[1.8]">One tap to generate a clean, professional PDF. Drop it straight into your report. No scanning, no redrawing, no wasted time.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PRICING ===== -->
    <section class="py-32 px-6 md:px-10 bg-field-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="font-mono text-[0.65rem] tracking-[0.35em] uppercase text-field-blue mb-5">Pricing</p>
          <h2 class="font-field font-bold tracking-[-0.02em] text-4xl md:text-[3.2rem] text-ink mb-4 leading-tight">Simple pricing.</h2>
          <p class="text-field-slate text-lg">Professional tools shouldn't cost a fortune. Expensable on most project budgets.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-7">
          <!-- Free -->
          <div class="reveal rounded-[1.5rem] p-9 border border-field-grid/40 bg-white shadow-sm">
            <p class="text-sketch-gray text-sm font-medium mb-3">Free</p>
            <p class="font-field font-bold tracking-tight text-[3.5rem] text-ink leading-none mb-1">$0</p>
            <p class="text-sketch-gray text-sm mb-9">Forever free</p>
            <ul class="space-y-3.5 mb-9">
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue">&#10003;</span> Core drawing tools</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue">&#10003;</span> 5 saved sketches</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue">&#10003;</span> PDF export (watermarked)</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/35"><span>&#10007;</span> Unlimited sketches</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/35"><span>&#10007;</span> Clean PDF export</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/35"><span>&#10007;</span> Templates library</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/35"><span>&#10007;</span> Cloud sync</li>
            </ul>
            <button class="w-full py-4 rounded-2xl border border-field-grid text-sketch-gray font-display font-semibold text-sm hover:border-field-blue hover:text-field-blue transition-colors duration-300">
              Coming soon
            </button>
          </div>
          <!-- Pro -->
          <div class="reveal relative overflow-hidden rounded-[1.5rem] p-9 text-white" style="background: linear-gradient(140deg, #1D4ED8 0%, #1a3f9e 40%, #1E3A5F 100%); transition-delay: 0.1s">
            <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="bp-price" width="20" height="20" patternUnits="userSpaceOnUse">
                  <path d="M 20 0 L 0 0 0 20" fill="none" stroke="white" stroke-width="0.35"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#bp-price)"/>
            </svg>
            <div class="relative">
              <div class="flex items-center justify-between mb-3">
                <p class="text-white/60 text-sm font-medium">Pro</p>
                <span class="px-2.5 py-1 rounded-full bg-white/[0.08] font-mono text-[0.6rem] text-white/50 tracking-wider uppercase">most popular</span>
              </div>
