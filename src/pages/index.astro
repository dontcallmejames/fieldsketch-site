---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---
<Base
  title="FieldSketch — Field Inspection Sketches, Done Right"
  description="Purpose-built for field engineers, site inspectors, architects, and construction professionals. Sketch on your iPad, export clean PDFs, drop them in your reports."
>
  <div class="bg-field-white min-h-screen">

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-field-white/90 backdrop-blur border-b border-field-blue/10">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="https://sketchkit.app" class="text-sm font-medium text-sketch-gray hover:text-ink transition-colors">← SketchKit</a>
        <Logo size={36} variant="dark" />
        <a href="https://moodsketch.app" class="text-sm font-medium text-sketch-gray hover:text-ink transition-colors">MoodSketch →</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-field-blue to-field-dark text-white pt-24 pb-32 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-white/70 text-sm font-medium tracking-widest uppercase mb-6">For iPad</p>
        <h1 class="font-display font-bold tracking-tight text-7xl md:text-8xl leading-none mb-6">FieldSketch</h1>
        <p class="text-white/80 text-2xl md:text-3xl font-medium mb-4">Field inspection sketches, done right.</p>
        <p class="text-white/60 text-lg max-w-xl mx-auto mb-12 leading-relaxed">
          Replace your clipboard and paper notebook with something that actually works in the field.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-white/20 hover:bg-white/30 backdrop-blur text-white font-semibold text-base transition-all border border-white/30">
            🍎 App Store — Coming Soon
          </button>
          <button class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-white/20 hover:bg-white/30 backdrop-blur text-white font-semibold text-base transition-all border border-white/30">
            ▶ Google Play — Coming Soon
          </button>
        </div>
      </div>
    </section>

    <!-- Audience callout -->
    <section class="bg-field-blue/5 border-b border-field-grid py-8 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-center text-field-slate text-sm font-medium">
          Built for <span class="text-ink font-semibold">field engineers</span> · <span class="text-ink font-semibold">site inspectors</span> · <span class="text-ink font-semibold">architects</span> · <span class="text-ink font-semibold">construction professionals</span>
        </p>
      </div>
    </section>

    <!-- Features -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-display font-bold tracking-tight text-4xl text-ink text-center mb-16 fade-up">Built for the way you actually work.</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="fade-up">
            <div class="w-14 h-14 rounded-xl bg-field-blue/10 flex items-center justify-center mb-6 text-2xl">📱</div>
            <h3 class="font-display font-bold tracking-tight text-xl text-ink mb-3">Built for the Field</h3>
            <p class="text-field-slate leading-relaxed">Optimized for iPad. Gloves-friendly touch targets. Works completely offline — no signal, no problem. Your sketches are there when you need them.</p>
          </div>
          <div class="fade-up" style="transition-delay: 0.1s">
            <div class="w-14 h-14 rounded-xl bg-field-blue/10 flex items-center justify-center mb-6 text-2xl">📄</div>
            <h3 class="font-display font-bold tracking-tight text-xl text-ink mb-3">Report-Ready Output</h3>
            <p class="text-field-slate leading-relaxed">Export clean, professional PDFs with one tap. Drop them straight into your reports. No scanning, no photographing whiteboards, no cleanup.</p>
          </div>
          <div class="fade-up" style="transition-delay: 0.2s">
            <div class="w-14 h-14 rounded-xl bg-field-blue/10 flex items-center justify-center mb-6 text-2xl">📐</div>
            <h3 class="font-display font-bold tracking-tight text-xl text-ink mb-3">Smart Templates</h3>
            <p class="text-field-slate leading-relaxed">Pre-built templates for common inspection types — pipe layouts, floor plans, site overviews, mechanical diagrams. Start with structure, add detail.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Before / After -->
    <section class="bg-field-blue/5 py-24 px-6 border-y border-field-grid">
      <div class="max-w-3xl mx-auto fade-up">
        <h2 class="font-display font-bold tracking-tight text-4xl text-ink text-center mb-16">Before FieldSketch. After FieldSketch.</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-2xl p-8 border border-field-grid">
            <p class="text-field-slate text-sm font-medium uppercase tracking-wide mb-6">Before</p>
            <ul class="space-y-4 text-field-slate">
              <li class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span> Paper sketch on clipboard, hard to read later</li>
              <li class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span> Photograph the whiteboard, hope the lighting is okay</li>
              <li class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span> Redraw the sketch in the office for the report</li>
              <li class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span> 20-30 minutes of cleanup per inspection</li>
            </ul>
          </div>
          <div class="bg-gradient-to-br from-field-blue to-field-dark rounded-2xl p-8 text-white">
            <p class="text-white/70 text-sm font-medium uppercase tracking-wide mb-6">After</p>
            <ul class="space-y-4 text-white/90">
              <li class="flex items-start gap-3"><span class="text-field-blue-light mt-0.5 flex-shrink-0">✓</span> Sketch on iPad, clean and legible every time</li>
              <li class="flex items-start gap-3"><span class="text-field-blue-light mt-0.5 flex-shrink-0">✓</span> One-tap PDF export, report-ready immediately</li>
              <li class="flex items-start gap-3"><span class="text-field-blue-light mt-0.5 flex-shrink-0">✓</span> Drop the PDF straight into your report</li>
              <li class="flex items-start gap-3"><span class="text-field-blue-light mt-0.5 flex-shrink-0">✓</span> Save 20+ minutes per inspection</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-24 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display font-bold tracking-tight text-4xl text-ink text-center mb-4 fade-up">Simple pricing.</h2>
        <p class="text-field-slate text-center mb-16 fade-up">Professional tools shouldn't cost a fortune. Expensable on most project budgets.</p>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Free -->
          <div class="fade-up bg-white rounded-2xl p-8 border border-light-rule">
            <p class="text-sketch-gray text-sm font-medium mb-2">Free</p>
            <p class="font-display font-bold tracking-tight text-4xl text-ink mb-1">$0</p>
            <p class="text-sketch-gray text-sm mb-8">Forever free</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue">✓</span> Core drawing tools</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue">✓</span> 5 saved sketches</li>
              <li class="flex items-center gap-3 text-sm text-ink"><span class="text-field-blue">✓</span> PDF export (watermarked)</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/50"><span>✗</span> Unlimited sketches</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/50"><span>✗</span> Clean PDF export</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/50"><span>✗</span> Templates library</li>
              <li class="flex items-center gap-3 text-sm text-sketch-gray/50"><span>✗</span> Cloud sync</li>
            </ul>
            <button class="w-full py-3 rounded-xl border border-light-rule text-sketch-gray font-semibold text-sm hover:border-field-blue hover:text-field-blue transition-colors">
              Coming soon
            </button>
          </div>
          <!-- Pro -->
          <div class="fade-up bg-gradient-to-br from-field-blue to-field-dark rounded-2xl p-8 text-white" style="transition-delay: 0.1s">
            <p class="text-white/70 text-sm font-medium mb-2">Pro</p>
            <p class="font-display font-bold tracking-tight text-4xl mb-1">$9.99<span class="text-xl font-normal text-white/70">/mo</span></p>
            <p class="text-white/60 text-sm mb-8">or $79.99/yr — save 33%</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light">✓</span> Everything in Free</li>
              <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light">✓</span> Unlimited sketches</li>
              <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light">✓</span> Clean PDF export</li>
              <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light">✓</span> Full template library</li>
              <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light">✓</span> Cloud sync</li>
              <li class="flex items-center gap-3 text-sm"><span class="text-field-blue-light">✓</span> Priority support</li>
            </ul>
            <button class="w-full py-3 rounded-xl bg-white text-field-blue font-semibold text-sm hover:bg-white/90 transition-colors">
              Coming soon
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Email Capture -->
    <section class="bg-field-dark py-24 px-6">
      <div class="max-w-lg mx-auto text-center fade-up">
        <h2 class="font-display font-bold tracking-tight text-4xl text-white mb-4">Get early access.</h2>
        <p class="text-white/60 text-lg mb-10">Get notified when FieldSketch launches. First users get 3 months Pro free.</p>
        <form action="https://formspree.io/f/REPLACE_ME" method="POST" class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 px-5 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-field-blue-light text-base"
          />
          <button
            type="submit"
            class="px-8 py-4 rounded-xl bg-field-blue hover:bg-field-blue/80 text-white font-semibold text-base transition-colors whitespace-nowrap"
          >
            Notify me
          </button>
        </form>
        <p class="text-white/30 text-sm mt-4">No spam. Unsubscribe anytime.</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink py-12 px-6">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <Logo size={36} opacity="0.7" />
        <div class="flex items-center gap-8">
          <a href="https://sketchkit.app" class="text-sm text-white/40 hover:text-white/80 transition-colors">Home</a>
          <a href="https://moodsketch.app" class="text-sm text-white/40 hover:text-white/80 transition-colors">MoodSketch</a>
        </div>
        <p class="text-sm text-white/30">© 2026 SketchKit</p>
      </div>
    </footer>

  </div>
</Base>
